# ============================================================
# Environment Configuration — copy to .env and fill in values
# ============================================================

# --- OpenAI (required for LLM and embeddings) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini               # Cost-effective for demonstration

# --- LangSmith Observability (optional but recommended) ---
# Sign up free at https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=clinical-research-agent

# --- MCP Tool Server ---
MCP_SERVER_URL=http://localhost:8001    # FastAPI server started by mcp_server.py
MCP_SERVER_PORT=8001
